# ──────────────────────────────────────────────────────────────────────────────
# Zomato User API — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Zomato User API"
APP_VERSION="1.0.0"
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver required for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/zomato_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=changeme_use_a_long_random_secret_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── OTP ───────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=3
OTP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW=300

# ── Pagination ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8000","http://127.0.0.1:8000"]
